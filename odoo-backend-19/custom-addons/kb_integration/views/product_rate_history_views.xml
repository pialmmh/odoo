<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view -->
    <record id="view_product_rate_history_tree" model="ir.ui.view">
        <field name="name">product.rate.history.tree</field>
        <field name="model">product.rate.history</field>
        <field name="arch" type="xml">
            <list decoration-success="is_active == True"
                  decoration-muted="is_active == False">
                <field name="product_tmpl_id"/>
                <field name="variant_display" optional="show"/>
                <field name="price" string="Price (BDT)"/>
                <field name="pricelist_tier"/>
                <field name="effective_date"/>
                <field name="end_date"/>
                <field name="is_active"/>
                <field name="reason" optional="show"/>
                <field name="changed_by" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_product_rate_history_form" model="ir.ui.view">
        <field name="name">product.rate.history.form</field>
        <field name="model">product.rate.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Product">
                            <field name="product_tmpl_id"/>
                            <field name="product_id"
                                   domain="[('product_tmpl_id', '=', product_tmpl_id)]"/>
                            <field name="pricelist_tier"/>
                            <field name="pricelist_id"/>
                        </group>
                        <group string="Rate">
                            <field name="price"/>
                            <field name="currency_id"/>
                            <field name="tax_included"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <group>
                        <group string="Effective Period">
                            <field name="effective_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Audit">
                            <field name="reason"/>
                            <field name="changed_by"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_product_rate_history_search" model="ir.ui.view">
        <field name="name">product.rate.history.search</field>
        <field name="model">product.rate.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_tmpl_id"/>
                <field name="product_id"/>
                <field name="reason"/>
                
                <filter name="active_rates" string="Active Rates" domain="[('is_active', '=', True)]"/>
                <filter name="expired" string="Expired" domain="[('is_active', '=', False)]"/>
                
                <filter name="standard" string="Standard" domain="[('pricelist_tier', '=', 'standard')]"/>
                <filter name="enterprise" string="Enterprise" domain="[('pricelist_tier', '=', 'enterprise')]"/>
                <filter name="government" string="Government" domain="[('pricelist_tier', '=', 'government')]"/>
                
                <group>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_tmpl_id'}"/>
                    <filter name="group_tier" string="Tier" context="{'group_by': 'pricelist_tier'}"/>
                    <filter name="group_effective" string="Effective Date" context="{'group_by': 'effective_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_product_rate_history" model="ir.actions.act_window">
        <field name="name">Rate History</field>
        <field name="res_model">product.rate.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_rate_history_search"/>
        <field name="context">{'search_default_active_rates': 1}</field>
    </record>

    <!-- Menu under Kill Bill -->
    <menuitem id="menu_kb_rate_history"
              name="Rate History"
              parent="menu_kb_root"
              action="action_product_rate_history"
              sequence="20"/>
</odoo>
