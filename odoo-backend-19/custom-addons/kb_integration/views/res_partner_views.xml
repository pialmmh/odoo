<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_kb" model="ir.ui.view">
        <field name="name">res.partner.form.kb</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="Kill Bill" name="killbill">
                    <group>
                        <group string="Account Mapping">
                            <field name="x_external_key"/>
                            <field name="x_kb_account_id"/>
                            <field name="x_kb_balance"/>
                        </group>
                        <group string="Verification">
                            <field name="x_verification_status" widget="radio"/>
                            <field name="x_nid_passport"/>
                            <field name="x_document_attachment" filename="x_document_filename"/>
                            <field name="x_document_filename" invisible="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
