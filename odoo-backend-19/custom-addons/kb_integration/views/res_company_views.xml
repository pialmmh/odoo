<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_kb" model="ir.ui.view">
        <field name="name">res.company.form.kb</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Kill Bill Integration">
                    <group>
                        <field name="x_kb_api_key"/>
                        <field name="x_kb_api_secret" password="True"/>
                    </group>
                    <group>
                        <field name="x_kb_tenant_id"/>
                        <field name="x_kb_api_url"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
