<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pbx_extension_tree" model="ir.ui.view">
        <field name="name">pbx.extension.list</field>
        <field name="model">pbx.extension</field>
        <field name="arch" type="xml">
            <list>
                <field name="extension"/>
                <field name="domain_name"/>
                <field name="user_id"/>
                <field name="state" decoration-success="state=='available'"
                                    decoration-warning="state=='assigned'"
                                    decoration-muted="state=='disabled'"/>
            </list>
        </field>
    </record>

    <record id="view_pbx_extension_form" model="ir.ui.view">
        <field name="name">pbx.extension.form</field>
        <field name="model">pbx.extension</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,assigned,disabled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="extension"/>
                            <field name="domain_name"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group string="PBX Identifiers">
                        <field name="domain_uuid"/>
                        <field name="extension_uuid"/>
                    </group>
                    <group string="SIP">
                        <field name="sip_username"/>
                        <field name="sip_password" password="True"/>
                    </group>
                    <field name="notes" placeholder="Operational notes…"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pbx_extension_search" model="ir.ui.view">
        <field name="name">pbx.extension.search</field>
        <field name="model">pbx.extension</field>
        <field name="arch" type="xml">
            <search>
                <field name="extension"/>
                <field name="domain_name"/>
                <field name="user_id"/>
                <filter string="Available" name="available" domain="[('state','=','available')]"/>
                <filter string="Assigned"  name="assigned"  domain="[('state','=','assigned')]"/>
                <filter string="Disabled"  name="disabled"  domain="[('state','=','disabled')]"/>
                <group>
                    <filter string="Domain" name="group_domain" context="{'group_by': 'domain_name'}"/>
                    <filter string="State"  name="group_state"  context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pbx_extension" model="ir.actions.act_window">
        <field name="name">PBX Extensions</field>
        <field name="res_model">pbx.extension</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
