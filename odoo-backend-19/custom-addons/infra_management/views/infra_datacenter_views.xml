<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Datacenter Tree -->
    <record id="view_infra_datacenter_tree" model="ir.ui.view">
        <field name="name">infra.datacenter.tree</field>
        <field name="model">infra.datacenter</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="zone_id"/>
                <field name="region_id"/>
                <field name="dc_type"/>
                <field name="tier"/>
                <field name="partner_id"/>
                <field name="is_dr_site"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Datacenter Form -->
    <record id="view_infra_datacenter_form" model="ir.ui.view">
        <field name="name">infra.datacenter.form</field>
        <field name="model">infra.datacenter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Datacenter Name"/></h1>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="zone_id"/>
                            <field name="region_id"/>
                            <field name="location_address"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                        <group string="Details">
                            <field name="dc_type"/>
                            <field name="tier"/>
                            <field name="partner_id"/>
                            <field name="is_dr_site"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Computes">
                            <field name="compute_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="hostname"/>
                                    <field name="node_type"/>
                                    <field name="cpu_cores"/>
                                    <field name="memory_gb"/>
                                    <field name="management_ip"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Network Devices">
                            <field name="network_device_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="device_model_id"/>
                                    <field name="device_attribute_ids" widget="many2many_tags"/>
                                    <field name="management_ip"/>
                                    <field name="operational_status"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Storage">
                            <field name="storage_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="storage_type"/>
                                    <field name="capacity_gb"/>
                                    <field name="used_gb"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Networks">
                            <field name="networking_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="network_type"/>
                                    <field name="cidr"/>
                                    <field name="vlan_id"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Resource Pools">
                            <field name="pool_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="pool_type"/>
                                    <field name="total_cpu_cores"/>
                                    <field name="total_memory_gb"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Datacenter Search -->
    <record id="view_infra_datacenter_search" model="ir.ui.view">
        <field name="name">infra.datacenter.search</field>
        <field name="model">infra.datacenter</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="zone_id"/>
                <field name="partner_id"/>
                
                <filter name="active" string="Active" domain="[('status','=','active')]"/>
                <filter name="dr_sites" string="DR Sites" domain="[('is_dr_site','=',True)]"/>
                <group>
                    <filter name="group_region" string="Region" context="{'group_by': 'region_id'}"/>
                    <filter name="group_zone" string="Zone" context="{'group_by': 'zone_id'}"/>
                    <filter name="group_type" string="DC Type" context="{'group_by': 'dc_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Datacenter Action -->
    <record id="action_infra_datacenter" model="ir.actions.act_window">
        <field name="name">Datacenters</field>
        <field name="res_model">infra.datacenter</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_infra_datacenter_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_infra_datacenters"
              name="Datacenters"
              parent="menu_infra_topology"
              action="action_infra_datacenter"
              sequence="30"/>

    <!-- Resource Pool Action -->
    <record id="action_infra_resource_pool" model="ir.actions.act_window">
        <field name="name">Resource Pools</field>
        <field name="res_model">infra.resource.pool</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_infra_pools"
              name="Resource Pools"
              parent="menu_infra_topology"
              action="action_infra_resource_pool"
              sequence="40"/>
</odoo>
