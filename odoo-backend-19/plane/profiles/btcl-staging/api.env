# Plane Django backend env — rendered per profile from operators/<op>.conf
# Lives at odoo-backend-19/plane/profiles/<op>-<profile>/api.env
# Copied into apps/api/.env at deploy time.
#
# DATABASE_URL points at the SAME Postgres that Odoo uses (catalog single source).
# The compose file's plane-db service is left running idle (or excluded) — Plane
# Django talks to the remote DB instead.

DEBUG=0
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3100"

# ── Database (shared with Odoo) ──
POSTGRES_USER="admin"
POSTGRES_PASSWORD="cHrZCGZZJtenNpg9TwREvpIbT2AwVQh"
POSTGRES_HOST="10.10.199.41"
POSTGRES_DB="platform_staging"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:cHrZCGZZJtenNpg9TwREvpIbT2AwVQh@10.10.199.41:5432/platform_staging

# ── Redis (compose-internal) ──
REDIS_HOST="plane-redis"
REDIS_PORT="6379"
REDIS_URL="redis://plane-redis:6379/"

# ── RabbitMQ (compose-internal) ──
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="plane"
RABBITMQ_PASSWORD="plane"
RABBITMQ_VHOST="plane"

# ── Object storage (compose-internal minio) ──
AWS_REGION=""
AWS_ACCESS_KEY_ID="access-key"
AWS_SECRET_ACCESS_KEY="secret-key"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
FILE_SIZE_LIMIT=5242880
SIGNED_URL_EXPIRATION=3600
USE_MINIO=1

DOCKERIZED=1
SECRET_KEY="7wmow7lt2b0sefygnbfvvfzf16hagrbj9u364r9ct1ghw2zdud"

# ── URLs ──
WEB_URL="http://localhost:7111"

GUNICORN_WORKERS=2

ADMIN_BASE_URL="http://localhost:3001"
ADMIN_BASE_PATH="/god-mode"
SPACE_BASE_URL="http://localhost:3002"
SPACE_BASE_PATH="/spaces"
APP_BASE_URL="http://localhost:3000"
APP_BASE_PATH=""
LIVE_BASE_URL="http://localhost:3100"
LIVE_BASE_PATH="/live"

LIVE_SERVER_SECRET_KEY="7wmow7lt2b0sefygnbfvvfzf16hagrbj9u364r9ct1ghw2zdud"
HARD_DELETE_AFTER_DAYS=60
MINIO_ENDPOINT_SSL=0
API_KEY_RATE_LIMIT="60/minute"
