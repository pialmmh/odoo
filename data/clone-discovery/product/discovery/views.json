{
  "kanban": {
    "arch": "<kanban sample=\"1\">\n                <field name=\"id\"/>\n                <field name=\"product_variant_count\"/>\n                <field name=\"currency_id\"/>\n                <field name=\"activity_state\"/>\n                <field name=\"categ_id\" on_change=\"1\"/>\n                <progressbar field=\"activity_state\" colors=\"{&quot;planned&quot;: &quot;success&quot;, &quot;today&quot;: &quot;warning&quot;, &quot;overdue&quot;: &quot;danger&quot;}\"/>\n                <templates>\n                    <t t-name=\"kanban-box\">\n                        <div class=\"oe_kanban_card oe_kanban_global_click\">\n                            <div class=\"o_kanban_image me-1\">\n                                <img t-att-src=\"kanban_image('product.template', 'image_128', record.id.raw_value)\" alt=\"Product\" class=\"o_image_64_contain\"/>\n                            </div>\n                            <div class=\"oe_kanban_details\">\n                                <div class=\"o_kanban_record_top mb-0\">\n                                    <div class=\"o_kanban_record_headings\">\n                                        <strong class=\"o_kanban_record_title\">\n                                            <field name=\"name\"/>\n                                        </strong>\n                                    </div>\n                                    <field name=\"priority\" widget=\"priority\"/>\n                                </div>\n                                <t t-if=\"record.default_code.value\">[<field name=\"default_code\" on_change=\"1\"/>]</t>\n                                <div t-if=\"record.product_variant_count.value &gt; 1\">\n                                    <strong>\n                                        <t t-esc=\"record.product_variant_count.value\"/> Variants\n                                    </strong>\n                                </div>\n                                <div name=\"product_lst_price\" class=\"mt-1\">\n                                    Price: <field name=\"list_price\" widget=\"monetary\" options=\"{'currency_field': 'currency_id', 'field_digits': True}\"/>\n                                </div>\n                    <div t-if=\"record.show_on_hand_qty_status_button.raw_value\">On hand: <field name=\"qty_available\"/> <field name=\"uom_id\" on_change=\"1\"/></div>\n                    <div>\n                                    <field name=\"product_properties\" widget=\"properties\"/>\n                                </div>\n                            </div>\n                        </div>\n                    </t>\n                </templates>\n                    <field name=\"type\" on_change=\"1\"/>\n                    <field name=\"show_on_hand_qty_status_button\"/>\n            </kanban>",
