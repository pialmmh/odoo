    "arch": "<search string=\"Product\">\n                <field name=\"name\" string=\"Product\" filter_domain=\"['|', '|', '|', ('default_code', 'ilike', self), ('product_variant_ids.default_code', 'ilike', self),('name', 'ilike', self), ('barcode', 'ilike', self)]\"/>\n                <field name=\"categ_id\" filter_domain=\"[('categ_id', 'child_of', raw_value)]\"/>\n                <separator/>\n                <filter string=\"Services\" name=\"services\" domain=\"[('type','=','service')]\"/>\n                <filter string=\"Products\" name=\"consumable\" domain=\"[('type', 'in', ['consu', 'product'])]\"/>\n                <separator/>\n                <filter string=\"Can be Sold\" name=\"filter_to_sell\" domain=\"[('sale_ok','=',True)]\"/>\n                <filter string=\"Can be Purchased\" name=\"filter_to_purchase\" domain=\"[('purchase_ok', '=', True)]\"/>\n                <separator/>\n                <field string=\"Attributes\" name=\"attribute_line_ids\"/>\n                <filter invisible=\"1\" string=\"Late Activities\" name=\"activities_overdue\" domain=\"[('my_activity_date_deadline', '&lt;', context_today().strftime('%Y-%m-%d'))]\" help=\"Show all records which has next action date is before today\"/>\n                <filter invisible=\"1\" string=\"Today Activities\" name=\"activities_today\" domain=\"[('my_activity_date_deadline', '=', context_today().strftime('%Y-%m-%d'))]\"/>\n                <filter invisible=\"1\" string=\"Future Activities\" name=\"activities_upcoming_all\" domain=\"[('my_activity_date_deadline', '&gt;', context_today().strftime('%Y-%m-%d'))                     ]\"/>\n                <separator/>\n                <filter string=\"Favorites\" name=\"favorites\" domain=\"[('priority','=','1')]\"/>\n                <separator/>\n                <filter string=\"Warnings\" name=\"activities_exception\" domain=\"[('activity_exception_decoration', '!=', False)]\"/>\n                <separator/>\n                <filter string