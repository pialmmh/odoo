  "tree_default": {
    "arch": "<tree string=\"Product\" multi_edit=\"1\" sample=\"1\">\n            <header>\n                <button string=\"Print Labels\" type=\"object\" name=\"action_open_label_layout\"/>\n            </header>\n                <field name=\"product_variant_count\" column_invisible=\"True\"/>\n                <field name=\"sale_ok\" column_invisible=\"True\"/>\n                <field name=\"currency_id\" column_invisible=\"True\"/>\n                <field name=\"cost_currency_id\" column_invisible=\"True\"/>\n                <field name=\"priority\" widget=\"priority\" optional=\"show\" nolabel=\"1\"/>\n                <field name=\"name\" string=\"Product Name\"/>\n                <field name=\"default_code\" optional=\"show\" on_change=\"1\"/>\n                    <field name=\"responsible_id\" widget=\"many2one_avatar_user\" optional=\"hide\" can_create=\"True\" can_write=\"True\"/>\n                <field name=\"product_tag_ids\" widget=\"many2many_tags\" optional=\"show\" can_create=\"True\" can_write=\"True\"/>\n                <field name=\"barcode\" optional=\"hide\" readonly=\"product_variant_count != 1\"/>\n                \n                <field name=\"list_price\" string=\"Sales Price\" widget=\"monetary\" options=\"{'currency_field': 'currency_id'}\" optional=\"show\" decoration-muted=\"not sale_ok\"/>\n                <field name=\"standard_price\" widget=\"monetary\" options=\"{'currency_field': 'cost_currency_id'}\" optional=\"show\" readonly=\"1\"/>\n                <field name=\"categ_id\" optional=\"hide\" on_change=\"1\" can_create=\"True\" can_write=\"True\"/>\n                <field name=\"detailed_type\" optional=\"hide\" readonly=\"1\" on_change=\"1\"/>\n                <field name=\"type\" column_invisible=\"True\" on_change=\"1\"/>\n                    <field name=\"show_on_hand_qty_status_button\" column_invisible=\"True\"/>\n                    <field name=\"qty_available\" invisible=\"not show_on_hand_qty_status_button\" string=\"On Hand\" optional=\"show\" decoration-danger=\"qty_available &lt; 0\"/>\n                    <field name=\"virtual_available\" invisible=\"not show_on_hand_qty_status_button\" string=\"Forecasted\" optional=\"show\" decoration-danger=\"virtual_available &lt; 0\" decoration-bf=\"1\"/>\n                \n                <field name=\"active\" column_invisible=\"True\"/>\n                <field name=\"activity_exception_decoration\" widget=\"activity_exception\"/>\n            </tree>",
