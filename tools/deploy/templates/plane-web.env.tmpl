# Plane web (apps/web) — rendered per profile from operators/<op>/<profile>.yml
# Lives at odoo-backend-19/plane/profiles/<op>-<profile>/web.env
# Copied to apps/web/.env at deploy time (plane.sh).
#
# Vite reads `VITE_*` from this file at dev-server start. Changing values
# here requires restarting `pnpm turbo run dev` (Vite doesn't hot-reload env).

VITE_API_BASE_URL="http://localhost:{{plane_api_port}}"

VITE_WEB_BASE_URL="http://localhost:{{plane_web_port}}"

VITE_ADMIN_BASE_URL="http://localhost:{{plane_admin_port}}"
VITE_ADMIN_BASE_PATH="/god-mode"

VITE_SPACE_BASE_URL="http://localhost:{{plane_space_port}}"
VITE_SPACE_BASE_PATH="/spaces"

VITE_LIVE_BASE_URL="http://localhost:{{plane_live_port}}"
VITE_LIVE_BASE_PATH="/live"
