<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_kb" model="ir.ui.view">
        <field name="name">account.payment.form.kb</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Kill Bill">
                    <field name="x_kb_payment_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
